---
import { useTranslation } from '../i18n/ui';

interface Props {
  mdUrl: string;
  lang: 'en' | 'es';
}

const { mdUrl, lang } = Astro.props;
const t = useTranslation(lang);

const copyLabel = t('post.copyMarkdown');
const copiedLabel = t('post.copiedMarkdown');
---

{/* SVG icon templates — cloned by JS, avoids innerHTML */}
<template id="icon-clipboard-text">
  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 256 256" fill="currentColor">
    <path d="M200,32H163.74a47.92,47.92,0,0,0-71.48,0H56A16,16,0,0,0,40,48V216a16,16,0,0,0,16,16H200a16,16,0,0,0,16-16V48A16,16,0,0,0,200,32Zm-72,0a32,32,0,0,1,32,32H96A32,32,0,0,1,128,32Zm72,184H56V48H82.75A47.93,47.93,0,0,0,80,64v8a8,8,0,0,0,8,8h80a8,8,0,0,0,8-8V64a47.93,47.93,0,0,0-2.75-16H200ZM160,128a8,8,0,0,1-8,8H104a8,8,0,0,1,0-16h48A8,8,0,0,1,160,128Zm0,32a8,8,0,0,1-8,8H104a8,8,0,0,1,0-16h48A8,8,0,0,1,160,160Z" />
  </svg>
</template>
<template id="icon-md-check">
  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 256 256" fill="currentColor">
    <path d="M229.66,77.66l-128,128a8,8,0,0,1-11.32,0l-56-56a8,8,0,0,1,11.32-11.32L96,188.69,218.34,66.34a8,8,0,0,1,11.32,11.32Z" />
  </svg>
</template>

<button
  class="copy-md-btn inline-flex items-center gap-1 text-sm text-text-secondary hover:text-event-horizon transition-colors"
  aria-label={copyLabel}
  data-md-url={mdUrl}
  data-copy-label=".md"
  data-copied-label={copiedLabel}
>
  {/* Initial icon injected from template by JS — avoids duplicating the SVG */}
  <span data-copy-label>.md</span>
</button>

<script>
  function initCopyMarkdown() {
    const clipboardTpl = document.getElementById('icon-clipboard-text') as HTMLTemplateElement;
    const checkTpl = document.getElementById('icon-md-check') as HTMLTemplateElement;
    if (!clipboardTpl || !checkTpl) return;

    document.querySelectorAll<HTMLButtonElement>('.copy-md-btn').forEach((btn) => {
      if (btn.dataset.initialized) return;
      btn.dataset.initialized = 'true';

      btn.prepend(clipboardTpl.content.cloneNode(true));

      let resetTimer: number | undefined;

      btn.addEventListener('click', async () => {
        const url = btn.dataset.mdUrl;
        if (!url) return;

        try {
          const res = await fetch(url);
          const text = await res.text();
          await navigator.clipboard.writeText(text);

          const labelSpan = btn.querySelector<HTMLSpanElement>('span[data-copy-label]');
          const icon = btn.querySelector<SVGElement>('svg');
          const copiedLabel = btn.dataset.copiedLabel ?? 'Copied!';
          const copyLabel = btn.dataset.copyLabel ?? '.md';

          if (labelSpan) labelSpan.textContent = copiedLabel;
          if (icon) icon.replaceWith(checkTpl.content.cloneNode(true));
          btn.style.color = 'var(--color-event-horizon)';

          clearTimeout(resetTimer);
          resetTimer = window.setTimeout(() => {
            if (labelSpan) labelSpan.textContent = copyLabel;
            const currentCheck = btn.querySelector<SVGElement>('svg');
            if (currentCheck) currentCheck.replaceWith(clipboardTpl.content.cloneNode(true));
            btn.style.color = '';
          }, 2000);
        } catch {
          // silently fail if fetch or clipboard fails
        }
      });
    });
  }

  initCopyMarkdown();
</script>
