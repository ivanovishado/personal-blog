---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
  lang?: string;
}

const { headings, lang = 'en' } = Astro.props;

// Only show h2 and h3
const filteredHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);

const tocTitle = lang === 'es' ? 'En esta pagina' : 'On this page';
---

{filteredHeadings.length > 0 && (
  <nav class="toc h-full" aria-label={tocTitle}>
    {/* Desktop: sticky sidebar */}
    <div class="hidden lg:block sticky top-24 max-h-[calc(100vh-8rem)] overflow-y-auto">
      <h4 class="font-heading text-sm font-semibold text-starlight mb-3">
        {tocTitle}
      </h4>
      <ul class="space-y-1.5 text-sm" id="toc-list">
        {filteredHeadings.map((heading) => (
          <li class:list={[heading.depth === 3 && 'ml-4']}>
            <a
              href={`#${heading.slug}`}
              class="toc-link block py-0.5 text-text-secondary hover:text-event-horizon transition-colors"
              data-slug={heading.slug}
            >
              {heading.text}
            </a>
          </li>
        ))}
      </ul>
    </div>

    {/* Mobile: collapsible */}
    <details class="lg:hidden rounded-lg border border-[var(--color-border)] bg-surface-800 p-4 mb-8">
      <summary class="font-heading text-sm font-semibold text-starlight cursor-pointer select-none">
        {tocTitle}
      </summary>
      <ul class="mt-3 space-y-1.5 text-sm">
        {filteredHeadings.map((heading) => (
          <li class:list={[heading.depth === 3 && 'ml-4']}>
            <a
              href={`#${heading.slug}`}
              class="toc-link block py-0.5 text-text-secondary hover:text-event-horizon transition-colors"
            >
              {heading.text}
            </a>
          </li>
        ))}
      </ul>
    </details>
  </nav>
)}

<style>
  .toc-link.active {
    color: var(--color-event-horizon);
    font-weight: 500;
  }
</style>

<script>
  let currentObserver: IntersectionObserver | null = null;

  function initTOCHighlighter() {
    currentObserver?.disconnect();
    currentObserver = null;

    const tocLinks = document.querySelectorAll<HTMLAnchorElement>('#toc-list .toc-link');
    if (tocLinks.length === 0) return;

    const slugToLink = new Map<string, HTMLAnchorElement>();
    const headingElements: HTMLElement[] = [];
    tocLinks.forEach((link) => {
      const slug = link.getAttribute('data-slug');
      if (slug) {
        slugToLink.set(slug, link);
        const el = document.getElementById(slug);
        if (el) headingElements.push(el);
      }
    });

    if (headingElements.length === 0) return;

    currentObserver = new IntersectionObserver(
      (entries) => {
        const lastIntersecting = [...entries].reverse().find((e) => e.isIntersecting);
        if (!lastIntersecting) return;
        tocLinks.forEach((link) => link.classList.remove('active'));
        slugToLink.get(lastIntersecting.target.id)?.classList.add('active');
      },
      {
        rootMargin: '-80px 0px -60% 0px',
        threshold: 0,
      },
    );

    headingElements.forEach((el) => currentObserver!.observe(el));
  }

  initTOCHighlighter();
  document.addEventListener('astro:after-swap', initTOCHighlighter);
</script>
