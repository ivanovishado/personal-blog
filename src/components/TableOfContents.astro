---
import { useTranslation } from '../i18n/ui';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
  lang?: string;
}

const { headings, lang = 'en' } = Astro.props;
const t = useTranslation(lang as 'en' | 'es');
const filteredHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);
const tocTitle = t('post.onThisPage');
---

{filteredHeadings.length > 0 && (
  <nav class="toc h-full" aria-label={tocTitle}>
    <div class="sticky top-24 max-h-[calc(100vh-8rem)] overflow-y-auto">
      <h4 class="font-heading text-sm font-semibold text-starlight mb-3">
        {tocTitle}
      </h4>
      <ul class="space-y-1.5 text-sm" id="toc-list">
        {filteredHeadings.map((heading) => (
          <li class:list={[heading.depth === 3 && 'ml-4']}>
            <a
              href={`#${heading.slug}`}
              class="toc-link block py-0.5 text-text-secondary hover:text-event-horizon transition-colors"
              data-slug={heading.slug}
            >
              {heading.text}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </nav>
)}

<style>
  .toc-link.active {
    color: var(--color-event-horizon);
    font-weight: 500;
  }
</style>
