---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  tags: string[];
  slug: string;
  lang: string;
  readingTime?: string;
  heroImage?: string;
  heroImageAlt?: string;
}

const { title, description, pubDate, tags, slug, lang, readingTime, heroImage, heroImageAlt } = Astro.props;

const formattedDate = new Intl.DateTimeFormat(lang === 'es' ? 'es-MX' : 'en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}).format(pubDate);

const href = `/${lang}/${slug}/`;
---

<article class="group">
  <a
    href={href}
    class="block rounded-xl border border-transparent p-4 -mx-4 transition-colors hover:border-border hover:bg-surface-800"
  >
    {heroImage && (
      <div class="mb-3 aspect-[16/9] overflow-hidden rounded-lg">
        <img
          src={heroImage}
          alt={heroImageAlt ?? title}
          loading="lazy"
          decoding="async"
          class="h-full w-full object-cover"
        />
      </div>
    )}
    <div class="mb-2 flex items-center gap-3 text-sm text-text-secondary">
      <time datetime={pubDate.toISOString()}>
        {formattedDate}
      </time>
      {readingTime && (
        <>
          <span aria-hidden="true">-</span>
          <span>{readingTime}</span>
        </>
      )}
    </div>
    <h3 class="font-heading text-xl font-bold text-starlight group-hover:text-event-horizon transition-colors">
      {title}
    </h3>
    <p class="mt-2 text-text-secondary leading-relaxed">
      {description}
    </p>
    {tags.length > 0 && (
      <div class="mt-3 flex flex-wrap gap-2">
        {tags.map((tag) => (
          <span class="rounded-full bg-surface-700 px-2.5 py-0.5 text-xs font-medium text-text-secondary">
            {tag}
          </span>
        ))}
      </div>
    )}
  </a>
</article>
