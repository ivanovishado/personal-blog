---
import BaseLayout from './BaseLayout.astro';
import TableOfContents from '../components/TableOfContents.astro';
import ReadingProgress from '../components/ReadingProgress.astro';
import LanguageSwitcher from '../components/LanguageSwitcher.astro';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  frontmatter: {
    title: string;
    description: string;
    pubDate: Date;
    updatedDate?: Date;
    heroImage?: string;
    heroImageAlt?: string;
    ogImage?: string;
    tags: string[];
    authors?: string[];
    lang: 'en' | 'es';
    translationSlug?: string;
    tldr?: string;
    readingTime?: string;
  };
  headings: Heading[];
}

const { frontmatter, headings } = Astro.props;

const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  heroImageAlt,
  ogImage,
  tags = [],
  authors = ['Ivan Galaviz'],
  lang = 'en',
  translationSlug,
  tldr,
  readingTime,
} = frontmatter;

const formattedPubDate = new Intl.DateTimeFormat(lang === 'es' ? 'es-MX' : 'en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}).format(new Date(pubDate));

const formattedUpdatedDate = updatedDate
  ? new Intl.DateTimeFormat(lang === 'es' ? 'es-MX' : 'en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    }).format(new Date(updatedDate))
  : null;
---

<BaseLayout
  title={title}
  description={description}
  ogImage={ogImage}
  lang={lang}
>
  {/* Top bar */}
  <header class="sticky top-0 z-40 border-b border-[var(--color-border)] bg-void/80 backdrop-blur-md">
    <div class="mx-auto flex max-w-5xl items-center justify-between px-4 py-3">
      <a
        href={`/${lang}/`}
        class="group inline-flex items-center gap-1.5 text-sm text-text-secondary hover:text-event-horizon transition-colors"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 256 256"
          fill="currentColor"
          class="transition-transform group-hover:-translate-x-0.5"
          aria-hidden="true"
        >
          <path d="M224,128a8,8,0,0,1-8,8H59.31l58.35,58.34a8,8,0,0,1-11.32,11.32l-72-72a8,8,0,0,1,0-11.32l72-72a8,8,0,0,1,11.32,11.32L59.31,120H216A8,8,0,0,1,224,128Z" />
        </svg>
        <span>Blog</span>
      </a>
      <div class="flex items-center gap-4">
        <LanguageSwitcher currentLang={lang} translationSlug={translationSlug} />
      </div>
    </div>

    {/* Reading progress (both viewports) */}
    {headings.length > 0 && (
      <ReadingProgress headings={headings} lang={lang} />
    )}
  </header>

  {/* Two-column layout: main content + sidebar TOC */}
  <div class="mx-auto max-w-5xl px-4 py-12 lg:grid lg:grid-cols-[1fr_220px] lg:gap-12">
    {/* Main content column */}
    <article class="min-w-0">
      {/* Article header */}
      <header class="mb-10">
        {/* Tags */}
        {tags.length > 0 && (
          <div class="mb-4 flex flex-wrap gap-1.5">
            {tags.map((tag) => (
              <span class="inline-block rounded-full bg-event-horizon/10 px-2.5 py-0.5 text-xs font-medium text-event-horizon">
                {tag}
              </span>
            ))}
          </div>
        )}

        {/* Title with gradient */}
        <h1 class="font-heading text-3xl font-bold leading-tight tracking-tight sm:text-4xl lg:text-5xl">
          <span class="bg-gradient-to-r from-starlight to-event-horizon bg-clip-text text-transparent">
            {title}
          </span>
        </h1>

        {/* Meta row */}
        <div class="mt-4 flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-text-secondary">
          <span>{authors.join(', ')}</span>
          <span class="text-text-tertiary">·</span>
          <time datetime={new Date(pubDate).toISOString()}>
            {formattedPubDate}
          </time>
          {readingTime && (
            <>
              <span class="text-text-tertiary">·</span>
              <span>{readingTime}</span>
            </>
          )}
        </div>

        {formattedUpdatedDate && (
          <p class="mt-2 text-xs text-text-tertiary italic">
            {lang === 'es' ? 'Actualizado' : 'Updated'}: {formattedUpdatedDate}
          </p>
        )}
      </header>

      {/* Hero image */}
      {heroImage && (
        <img
          src={heroImage}
          alt={heroImageAlt ?? title}
          class="mb-10 w-full rounded-xl"
          loading="eager"
          decoding="async"
        />
      )}

      {/* TL;DR box */}
      {tldr && (
        <aside class="mb-10 rounded-xl border border-event-horizon/20 bg-event-horizon/5 p-5">
          <p class="mb-1 font-heading text-xs font-semibold uppercase tracking-wider text-event-horizon">
            TL;DR
          </p>
          <p class="text-sm leading-relaxed text-text-secondary">
            {tldr}
          </p>
        </aside>
      )}

      {/* Rendered MDX content */}
      <div class="prose">
        <slot />
      </div>

      {/* Translation link at bottom */}
      {translationSlug && (
        <div class="mt-12 rounded-lg border border-[var(--color-border)] bg-surface-800 p-4 text-sm text-text-secondary">
          {lang === 'en' ? (
            <p>
              Este artículo también está disponible en{' '}
              <a href={`/es/${translationSlug}/`} class="text-event-horizon hover:underline">
                Español
              </a>.
            </p>
          ) : (
            <p>
              This article is also available in{' '}
              <a href={`/en/${translationSlug}/`} class="text-event-horizon hover:underline">
                English
              </a>.
            </p>
          )}
        </div>
      )}

      {/* Back to all posts */}
      <div class="mt-8">
        <a
          href={`/${lang}/`}
          class="inline-flex items-center gap-1.5 text-sm text-text-secondary hover:text-event-horizon transition-colors"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 256 256"
            fill="currentColor"
            aria-hidden="true"
          >
            <path d="M224,128a8,8,0,0,1-8,8H59.31l58.35,58.34a8,8,0,0,1-11.32,11.32l-72-72a8,8,0,0,1,0-11.32l72-72a8,8,0,0,1,11.32,11.32L59.31,120H216A8,8,0,0,1,224,128Z" />
          </svg>
          {lang === 'es' ? 'Volver al blog' : 'Back to blog'}
        </a>
      </div>
    </article>

    {/* Desktop TOC sidebar */}
    <aside class="hidden lg:block">
      <TableOfContents headings={headings} lang={lang} />
    </aside>
  </div>

</BaseLayout>
