---
/*
 * Icons: we use inline SVGs, NOT @phosphor-icons/web.
 * That package is a CSS icon font (4600+ lines of CSS + web font download),
 * not web components — the <ph-*> custom elements don't exist.
 * For ~8 icons on a static site, inline SVGs are lighter and render instantly.
 * See CopyCode.astro / CopyMarkdown.astro for the <template> + cloneNode()
 * pattern used for JS-driven icon swaps.
 */
import SEOHead from '../components/SEOHead.astro';
import Grain from '../components/Grain.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import CopyCode from '../components/CopyCode.astro';
import '../styles/tokens.css';
import '../styles/prose.css';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  lang?: string;
  canonicalURL?: string;
}

const {
  title,
  description,
  ogImage,
  lang = 'en',
  canonicalURL,
} = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    {/* Favicons */}
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    {/* Theme script — runs before CSS to prevent FOUC */}
    <script is:inline>
      if (localStorage.getItem('theme') !== 'light') {
        document.documentElement.classList.add('dark');
      }
    </script>

    {/* Umami */}
    <script
      is:inline
      defer
      src="https://umami-pearl-mu.vercel.app/script.js"
      data-website-id="ba17ed25-88a0-42ef-8fe8-6be75481e681"
    ></script>

    {/* Font preconnects */}
    <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
    <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    {/* Font stylesheets */}
    <link
      rel="stylesheet"
      href="https://api.fontshare.com/v2/css?f[]=cabinet-grotesk@1&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Source+Serif+4:ital,opsz,wght@0,8..60,200..900;1,8..60,200..900&family=JetBrains+Mono:wght@300..700&display=swap"
    />

    <SEOHead
      title={title}
      description={description}
      ogImage={ogImage}
      lang={lang}
      canonicalURL={canonicalURL}
    />
    <slot name="head" />

  </head>

  <body class="bg-void text-starlight min-h-screen font-prose antialiased">
    <slot />
    <div class="fixed bottom-6 right-6 z-50 rounded-full border border-[var(--color-border)] bg-void/80 shadow-lg backdrop-blur-md">
      <ThemeToggle />
    </div>
    <CopyCode />
    <Grain />
  </body>
</html>

<style is:global>
  /* Smooth page transitions */
  @view-transition {
    navigation: auto;
  }

  html {
    scroll-behavior: smooth;
  }

  /* Page transition animations */
  ::view-transition-old(root) {
    animation: fade-out 150ms ease-out;
  }

  ::view-transition-new(root) {
    animation: fade-in 150ms ease-in;
  }

  @keyframes fade-out {
    from { opacity: 1; }
    to { opacity: 0; }
  }

  @keyframes fade-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }
</style>
