{
  "name": "Orbital Light",
  "type": "light",
  "colors": {
    "editor.background": "#F8FAFC",
    "editor.foreground": "#1E293B",
    "editor.selectionBackground": "#E2E8F050",
    "editor.lineHighlightBackground": "#F1F5F9",
    "editorCursor.foreground": "#1D4ED8",
    "editorWhitespace.foreground": "#E2E8F0",
    "editorIndentGuide.background": "#F1F5F9",
    "editorLineNumber.foreground": "#94A3B8",
    "editorLineNumber.activeForeground": "#64748B"
  },
  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "comment.block",
        "comment.line",
        "comment.block.documentation",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#94A3B8",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.quoted.single",
        "string.quoted.double",
        "string.quoted.triple",
        "string.template",
        "string.quoted.other"
      ],
      "settings": {
        "foreground": "#B45309"
      }
    },
    {
      "name": "String interpolation",
      "scope": [
        "punctuation.definition.template-expression",
        "punctuation.section.embedded"
      ],
      "settings": {
        "foreground": "#1D4ED8"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.control.flow",
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from",
        "keyword.control.conditional",
        "keyword.control.loop",
        "keyword.control.trycatch",
        "keyword.other",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#1D4ED8"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "meta.function-call",
        "support.function",
        "meta.method-call entity.name.function"
      ],
      "settings": {
        "foreground": "#2563EB"
      }
    },
    {
      "name": "Types and classes",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.other.inherited-class",
        "support.type",
        "support.class",
        "entity.name.type.class",
        "meta.type.annotation",
        "entity.name.type.alias",
        "entity.name.type.interface",
        "entity.name.type.enum",
        "entity.name.type.module"
      ],
      "settings": {
        "foreground": "#1E40AF"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite",
        "variable.other.object",
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#1E293B"
      }
    },
    {
      "name": "Constants",
      "scope": [
        "constant",
        "constant.language",
        "constant.language.boolean",
        "variable.other.constant",
        "support.constant"
      ],
      "settings": {
        "foreground": "#2563EB"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric",
        "constant.numeric.integer",
        "constant.numeric.float",
        "constant.numeric.hex",
        "constant.numeric.octal",
        "constant.numeric.binary"
      ],
      "settings": {
        "foreground": "#B45309"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "keyword.operator.assignment",
        "keyword.operator.arithmetic",
        "keyword.operator.logical",
        "keyword.operator.comparison",
        "keyword.operator.ternary",
        "keyword.operator.spread",
        "keyword.operator.rest",
        "keyword.operator.type"
      ],
      "settings": {
        "foreground": "#64748B"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "punctuation.definition.block",
        "punctuation.definition.parameters",
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.accessor",
        "meta.brace.round",
        "meta.brace.square",
        "meta.brace.curly"
      ],
      "settings": {
        "foreground": "#64748B"
      }
    },
    {
      "name": "Errors",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#DC2626"
      }
    },
    {
      "name": "HTML/JSX Tags",
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag",
        "punctuation.definition.tag.begin",
        "punctuation.definition.tag.end"
      ],
      "settings": {
        "foreground": "#2563EB"
      }
    },
    {
      "name": "HTML/JSX Attributes",
      "scope": [
        "entity.other.attribute-name",
        "entity.other.attribute-name.html"
      ],
      "settings": {
        "foreground": "#1E40AF"
      }
    },
    {
      "name": "Properties",
      "scope": [
        "support.type.property-name",
        "meta.object-literal.key",
        "variable.other.property"
      ],
      "settings": {
        "foreground": "#1E40AF"
      }
    },
    {
      "name": "Support classes and built-ins",
      "scope": [
        "support.class.builtin",
        "support.variable",
        "variable.language",
        "variable.language.this",
        "variable.language.super"
      ],
      "settings": {
        "foreground": "#2563EB"
      }
    },
    {
      "name": "Regex",
      "scope": [
        "string.regexp",
        "string.regexp.js",
        "keyword.operator.quantifier.regexp",
        "keyword.control.anchor.regexp",
        "constant.other.character-class.regexp"
      ],
      "settings": {
        "foreground": "#B45309"
      }
    },
    {
      "name": "Markdown headings",
      "scope": [
        "markup.heading",
        "heading.1.markdown",
        "heading.2.markdown",
        "heading.3.markdown",
        "entity.name.section.markdown",
        "punctuation.definition.heading.markdown"
      ],
      "settings": {
        "foreground": "#2563EB",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown bold",
      "scope": [
        "markup.bold",
        "punctuation.definition.bold.markdown"
      ],
      "settings": {
        "foreground": "#1E293B",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown italic",
      "scope": [
        "markup.italic",
        "punctuation.definition.italic.markdown"
      ],
      "settings": {
        "foreground": "#1E293B",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown links",
      "scope": [
        "markup.underline.link",
        "markup.underline.link.markdown"
      ],
      "settings": {
        "foreground": "#1D4ED8"
      }
    },
    {
      "name": "Markdown code",
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code.block",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#B45309"
      }
    },
    {
      "name": "JSON keys",
      "scope": [
        "support.type.property-name.json",
        "string.json support.type.property-name"
      ],
      "settings": {
        "foreground": "#1E40AF"
      }
    },
    {
      "name": "CSS properties",
      "scope": [
        "support.type.property-name.css",
        "meta.property-name.css",
        "support.type.vendored.property-name.css"
      ],
      "settings": {
        "foreground": "#1E40AF"
      }
    },
    {
      "name": "CSS values",
      "scope": [
        "support.constant.property-value.css",
        "meta.property-value.css",
        "constant.numeric.css",
        "support.constant.color.css"
      ],
      "settings": {
        "foreground": "#B45309"
      }
    },
    {
      "name": "CSS selectors",
      "scope": [
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css",
        "entity.name.tag.css"
      ],
      "settings": {
        "foreground": "#2563EB"
      }
    },
    {
      "name": "CSS at-rules",
      "scope": [
        "keyword.control.at-rule.css",
        "keyword.control.at-rule.media.css",
        "keyword.control.at-rule.import.css"
      ],
      "settings": {
        "foreground": "#1D4ED8"
      }
    },
    {
      "name": "Decorators / Annotations",
      "scope": [
        "meta.decorator",
        "punctuation.decorator",
        "meta.annotation"
      ],
      "settings": {
        "foreground": "#2563EB"
      }
    },
    {
      "name": "Escape characters",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#64748B"
      }
    }
  ]
}
